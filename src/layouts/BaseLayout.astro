---
import '../styles/global.css';
import { useTranslations } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: 'sv' | 'en';
  activeNav?: 'home' | 'routes' | 'calendar' | 'gallery' | 'about' | 'contact';
}

const { title, description, lang = 'sv', activeNav } = Astro.props;
const t = useTranslations(lang);

const navBase = lang === 'en' ? '/en' : '';
const altLang = lang === 'en' ? 'sv' : 'en';
const altLangHref = lang === 'en' ? Astro.url.pathname.replace(/^\/en/, '') || '/' : `/en${Astro.url.pathname}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'Guidade motorcykelturer i Östergötland'} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title} — Brembo Tempo Tours</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600&family=Nunito:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 pt-3 pb-6 lg:px-8 lg:pt-3 lg:pb-8" style="background: linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0) 100%)">

      <!-- Logo -->
      <div id="site-logo" class="transition-opacity duration-300">
        <a href={navBase || '/'} class="flex items-center gap-1">
          <img src="/logos/btt.png" alt="" class="block h-12 lg:h-[72px] w-auto" />
          <div style="font-family: 'Nunito', sans-serif; font-weight: 900; line-height: 1.05;">
            <div class="text-[0.85rem] lg:text-[1.15rem] text-white" style="letter-spacing: 0.04em;">BREMBO TEMPO</div>
            <div class="text-[0.75rem] lg:text-[1.05rem] text-brand-gold" style="letter-spacing: 0.12em;">TOURS</div>
          </div>
        </a>
      </div>

      <!-- Hamburger -->
      <button id="menu-toggle" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="block w-6 h-px bg-white transition-all" id="burger-top"></span>
        <span class="block w-6 h-px bg-white transition-all" id="burger-mid"></span>
        <span class="block w-6 h-px bg-white transition-all" id="burger-bot"></span>
      </button>

      <!-- Nav links (desktop) -->
      <nav class="hidden lg:flex items-center gap-10">
        <a href={navBase || '/'} class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'home' ? 'text-brand-gold' : 'text-white/85 hover:text-white']}>{t.nav.home}</a>
        <a href={`${navBase}/routes`} class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'routes' ? 'text-brand-gold' : 'text-white/85 hover:text-white']}>{t.nav.routes}</a>
        <a href={`${navBase}/calendar`} class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'calendar' ? 'text-brand-gold' : 'text-white/85 hover:text-white']}>{t.nav.calendar}</a>
        <a href={`${navBase}/gallery`} class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'gallery' ? 'text-brand-gold' : 'text-white/85 hover:text-white']}>{t.nav.gallery}</a>
        <a href={`${navBase}/about`} class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'about' ? 'text-brand-gold' : 'text-white/85 hover:text-white']}>{t.nav.about}</a>
        <a href={`${navBase}/contact`} class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'contact' ? 'text-brand-gold' : 'text-white/85 hover:text-white']}>{t.nav.contact}</a>
        <a href={altLangHref} class="border border-white/30 px-3 py-1 text-[0.65rem] tracking-[0.15em] text-white/70 uppercase hover:border-brand-gold hover:text-brand-gold transition-colors">{altLang.toUpperCase()}</a>
      </nav>

    </header>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-40 bg-brand-dark/98 flex flex-col items-center justify-center gap-8 hidden lg:hidden">
      <a href={navBase || '/'} class:list={['text-[0.85rem] font-medium tracking-[0.25em] uppercase transition-colors', activeNav === 'home' ? 'text-brand-gold' : 'text-white/85']}>{t.nav.home}</a>
      <a href={`${navBase}/routes`} class:list={['text-[0.85rem] font-medium tracking-[0.25em] uppercase transition-colors', activeNav === 'routes' ? 'text-brand-gold' : 'text-white/85']}>{t.nav.routes}</a>
      <a href={`${navBase}/calendar`} class:list={['text-[0.85rem] font-medium tracking-[0.25em] uppercase transition-colors', activeNav === 'calendar' ? 'text-brand-gold' : 'text-white/85']}>{t.nav.calendar}</a>
      <a href={`${navBase}/gallery`} class:list={['text-[0.85rem] font-medium tracking-[0.25em] uppercase transition-colors', activeNav === 'gallery' ? 'text-brand-gold' : 'text-white/85']}>{t.nav.gallery}</a>
      <a href={`${navBase}/about`} class:list={['text-[0.85rem] font-medium tracking-[0.25em] uppercase transition-colors', activeNav === 'about' ? 'text-brand-gold' : 'text-white/85']}>{t.nav.about}</a>
      <a href={`${navBase}/contact`} class:list={['text-[0.85rem] font-medium tracking-[0.25em] uppercase transition-colors', activeNav === 'contact' ? 'text-brand-gold' : 'text-white/85']}>{t.nav.contact}</a>
      <a href={altLangHref} class="border border-white/30 px-4 py-2 text-[0.7rem] tracking-[0.15em] text-white/70 uppercase mt-4">{altLang.toUpperCase()}</a>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-black border-t border-white/[0.06] px-6 md:px-20 py-10 flex flex-col items-center gap-4">
      <a href={navBase || '/'}>
        <img src="/logos/btt.png" alt="Brembo Tempo Tours" class="h-[52px] w-auto" />
      </a>
      <span class="text-[0.7rem] text-white/20">{t.footer.copy}</span>
    </footer>

    <script>
      // Mobile menu toggle
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const burgerTop = document.getElementById('burger-top');
      const burgerMid = document.getElementById('burger-mid');
      const burgerBot = document.getElementById('burger-bot');
      let menuOpen = false;

      menuToggle?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        mobileMenu?.classList.toggle('hidden', !menuOpen);
        document.body.style.overflow = menuOpen ? 'hidden' : '';
        if (burgerTop && burgerMid && burgerBot) {
          burgerTop.style.transform = menuOpen ? 'rotate(45deg) translate(3px, 3px)' : '';
          burgerMid.style.opacity = menuOpen ? '0' : '1';
          burgerBot.style.transform = menuOpen ? 'rotate(-45deg) translate(3px, -3px)' : '';
        }
      });

      const logo   = document.getElementById('site-logo');
      const header = document.querySelector('header');
      const heroImg = document.querySelector('main > section:first-child img') as HTMLElement | null;

      // ── Combined scroll handler ──────────────────────────────────────────
      window.addEventListener('scroll', () => {
        const y = window.scrollY;

        // Logo fade-out as user scrolls into page
        if (logo) {
          const op = Math.max(0, 1 - y / 220);
          logo.style.opacity = String(op);
          logo.style.pointerEvents = op < 0.05 ? 'none' : 'auto';
        }

        // Header: transparent gradient → solid dark once past the hero
        if (header) {
          const pastHero = y > window.innerHeight * 0.8;
          (header as HTMLElement).style.background = pastHero
            ? 'rgba(13,13,13,0.96)'
            : 'linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0) 100%)';
        }

        // Hero image parallax — drifts up slightly as page scrolls
        if (heroImg) heroImg.style.transform = `translateY(${y * 0.22}px)`;
      }, { passive: true });

      // ── Intersection Observer for reveal animations ──────────────────────
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const delay = Number((entry.target as HTMLElement).dataset.delay ?? 0);
          setTimeout(() => entry.target.classList.add('in-view'), delay);
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      function watch(selector: string, stagger = 0) {
        document.querySelectorAll(selector).forEach((el, i) => {
          el.classList.add('reveal');
          if (stagger) (el as HTMLElement).dataset.delay = String(i * stagger);
          observer.observe(el);
        });
      }

      // Major content sections (skip first hero)
      watch('main > *:not(:first-child)', 0);

      // Stats bar cells — stagger each one
      watch('.bg-brand-gold.grid > div', 120);

      // Route cards
      watch('.route-row', 90);

      // Date / booking cards in 3-col grids
      watch('.grid.grid-cols-3 > a, .grid.grid-cols-3 > div', 110);

      // Calendar rows
      watch('.border-b.border-white\\/\\[0\\.06\\]', 55);

      // Gallery thumbnails
      watch('.grid .overflow-hidden', 70);

      // ── Gold accent lines grow-in ────────────────────────────────────────
      const lineObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('in-view');
          lineObserver.unobserve(entry.target);
        });
      }, { threshold: 0.8 });

      document.querySelectorAll('.w-8.h-px.bg-brand-gold, .w-10.h-px.bg-brand-gold, .w-6.h-px.bg-brand-gold').forEach(el => {
        const w = el.classList.contains('w-10') ? '2.5rem' : el.classList.contains('w-6') ? '1.5rem' : '2rem';
        (el as HTMLElement).style.setProperty('--line-w', w);
        el.classList.add('line-reveal');
        lineObserver.observe(el);
      });
    </script>

  </body>
</html>
