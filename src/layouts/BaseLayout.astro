---
import '../styles/global.css';
import { useTranslations } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: 'sv' | 'en';
  activeNav?: 'routes' | 'calendar' | 'about' | 'contact';
}

const { title, description, lang = 'sv', activeNav } = Astro.props;
const t = useTranslations(lang);

const navBase = lang === 'en' ? '/en' : '';
const altLang = lang === 'en' ? 'sv' : 'en';
const altLangHref = lang === 'en' ? Astro.url.pathname.replace(/^\/en/, '') || '/' : `/en${Astro.url.pathname}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'Guidade motorcykelturer i Östergötland'} />
    <title>{title} — Brembo Tempo Tours</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- Logo: fixed top-left, fades on scroll -->
    <div id="site-logo" class="fixed top-0 left-0 z-50 transition-opacity duration-300">
      <a href={navBase || '/'}>
        <img src="/logos/black-btt.jpg" alt="Brembo Tempo Tours" class="block h-[170px] w-auto" />
      </a>
    </div>

    <!-- Nav links: fixed top-right -->
    <nav class="fixed top-0 right-0 z-50 flex items-center gap-10 px-12 py-8">
      <a
        href={`${navBase}/routes`}
        class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'routes' ? 'text-brand-gold' : 'text-white/65 hover:text-white']}
      >{t.nav.routes}</a>
      <a
        href={`${navBase}/calendar`}
        class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'calendar' ? 'text-brand-gold' : 'text-white/65 hover:text-white']}
      >{t.nav.calendar}</a>
      <a
        href={`${navBase}/about`}
        class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'about' ? 'text-brand-gold' : 'text-white/65 hover:text-white']}
      >{t.nav.about}</a>
      <a
        href={`${navBase}/contact`}
        class:list={['nav-link text-[0.7rem] font-medium tracking-[0.18em] uppercase transition-colors', activeNav === 'contact' ? 'text-brand-gold' : 'text-white/65 hover:text-white']}
      >{t.nav.contact}</a>
      <a
        href={altLangHref}
        class="border border-white/20 px-3 py-1 text-[0.65rem] tracking-[0.15em] text-white/50 uppercase hover:border-brand-gold hover:text-brand-gold transition-colors"
      >{altLang.toUpperCase()}</a>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-black border-t border-white/[0.06] px-20 py-10 flex items-center justify-between">
      <a href={navBase || '/'}>
        <img src="/logos/black-btt.jpg" alt="Brembo Tempo Tours" class="h-[72px] w-auto" />
      </a>
      <span class="text-[0.7rem] text-white/20">{t.footer.copy}</span>
    </footer>

    <script>
      const logo = document.getElementById('site-logo');
      if (logo) {
        window.addEventListener('scroll', () => {
          const opacity = Math.max(0, 1 - window.scrollY / 220);
          logo.style.opacity = String(opacity);
          logo.style.pointerEvents = opacity < 0.05 ? 'none' : 'auto';
        }, { passive: true });
      }
    </script>

  </body>
</html>
