---
interface Props {
  slug: string;
  title: string;
  description: string;
  distance: number;
  duration: string;
  difficulty: 'lätt' | 'medel' | 'krävande';
  difficultyLabel: string;
  coverImage: string;
  dateCount: number;
  index: number;
  lang: 'sv' | 'en';
  readMore: string;
  datesLabel: string;
}

const { slug, title, description, distance, duration, difficulty, difficultyLabel, coverImage, dateCount, index, lang, readMore, datesLabel } = Astro.props;

const href = lang === 'en' ? `/en/routes/${slug}` : `/routes/${slug}`;

const diffClass = {
  lätt: 'bg-green-500/10 text-green-400 border border-green-500/25',
  medel: 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/25',
  krävande: 'bg-red-500/10 text-red-400 border border-red-500/25',
}[difficulty];
---

<a href={href} class="route-row group grid grid-cols-2 min-h-[480px] border-t border-white/[0.06] overflow-hidden" style={index % 2 !== 0 ? 'direction:rtl' : ''}>
  <div class="relative overflow-hidden" style={index % 2 !== 0 ? 'direction:ltr' : ''}>
    <img
      src={coverImage}
      alt={title}
      class="w-full h-full min-h-[480px] object-cover brightness-[0.7] group-hover:scale-[1.04] group-hover:brightness-[0.85] transition-all duration-700"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/15 to-transparent pointer-events-none"></div>
  </div>

  <div class="bg-brand-dark flex flex-col justify-center px-20 py-16" style={index % 2 !== 0 ? 'direction:ltr' : ''}>
    <div class="text-[5rem] font-display font-black text-white/[0.04] leading-none mb-[-1.5rem]">
      {String(index + 1).padStart(2, '0')}
    </div>
    <span class={`inline-flex text-[0.6rem] font-bold tracking-[0.18em] uppercase px-3 py-1 mb-4 w-fit ${diffClass}`}>
      {difficultyLabel}
    </span>
    <h2 class="font-display text-[2.5rem] font-bold leading-[1.1] mb-5 text-white">{title}</h2>
    <p class="text-[0.88rem] text-white/45 leading-[1.85] mb-8">{description}</p>
    <div class="flex gap-8 mb-10">
      <div>
        <span class="block font-display text-[1.4rem] font-bold text-white leading-none">{distance}</span>
        <span class="block text-[0.6rem] tracking-[0.15em] uppercase text-white/30 mt-1">km</span>
      </div>
      <div>
        <span class="block font-display text-[1.4rem] font-bold text-white leading-none">{duration}</span>
        <span class="block text-[0.6rem] tracking-[0.15em] uppercase text-white/30 mt-1">tid</span>
      </div>
      <div>
        <span class="block font-display text-[1.4rem] font-bold text-white leading-none">{dateCount}</span>
        <span class="block text-[0.6rem] tracking-[0.15em] uppercase text-white/30 mt-1">{datesLabel}</span>
      </div>
    </div>
    <span class="text-[0.7rem] font-semibold tracking-[0.2em] uppercase text-brand-gold border-b border-brand-gold/30 pb-[2px] w-fit group-hover:border-brand-gold transition-colors">
      {readMore}
    </span>
  </div>
</a>
