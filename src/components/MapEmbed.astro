---
interface Props {
  embedUrl: string;
  title: string;
}
const { embedUrl, title } = Astro.props;
---

<div class="overflow-hidden border border-white/[0.08]">
  <iframe
    src={embedUrl}
    title={title}
    loading="lazy"
    class="w-full h-[300px] grayscale-[0.3] contrast-[1.1] block"
    referrerpolicy="no-referrer"
  ></iframe>
</div>
<p class="text-[0.65rem] text-white/20 mt-2">© OpenStreetMap-bidragsgivare</p>
