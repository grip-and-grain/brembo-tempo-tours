---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';
import { fetchGalleryImages } from '../lib/drive-gallery';

const lang = 'sv';
const t = useTranslations(lang);

const images = await fetchGalleryImages();
---

<BaseLayout title={t.gallery.eyebrow} lang={lang} activeNav="gallery">

  <section class="bg-brand-dark px-6 md:px-20 pt-32 md:pt-48 pb-16 md:pb-24">
    <div class="flex items-center gap-4 mb-5">
      <div class="w-8 h-px bg-brand-gold"></div>
      <span class="text-[0.65rem] font-semibold tracking-[0.25em] uppercase text-brand-gold">{t.gallery.eyebrow}</span>
    </div>
    <h1 class="font-display text-[2.5rem] md:text-[4rem] font-bold mb-12 md:mb-16">{t.gallery.title}</h1>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-[2px]">
      {images.map((img) => (
        <a href={img.full} target="_blank" rel="noopener" class="group overflow-hidden aspect-[4/3]">
          <img
            src={img.thumbnail}
            alt={img.name}
            loading="lazy"
            class="w-full h-full object-cover brightness-[0.8] group-hover:brightness-100 group-hover:scale-[1.05] transition-all duration-500"
          />
        </a>
      ))}
    </div>

    {images.length === 0 && (
      <p class="text-white/35 text-center py-20">Inga bilder ännu.</p>
    )}
  </section>

</BaseLayout>
