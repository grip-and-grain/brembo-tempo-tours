---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import RouteCard from '../../../components/RouteCard.astro';
import { fetchRoutes } from '../../../lib/sheets';
import { useTranslations } from '../../../i18n';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=7200');

const lang = 'en';
const t = useTranslations(lang);
const routes = await fetchRoutes();
---

<BaseLayout title={t.nav.routes} lang={lang} activeNav="routes">

  <div class="bg-brand-dark px-6 md:px-20 pt-32 md:pt-48 pb-14">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-8 h-px bg-brand-gold"></div>
      <span class="text-[0.65rem] font-semibold tracking-[0.25em] uppercase text-brand-gold">{t.route.eyebrow}</span>
    </div>
    <h1 class="font-display text-[2.5rem] md:text-[4rem] font-black leading-none">
      {t.route.chooseTitle1}<br />
      <em class="italic text-brand-gold">{t.route.chooseTitleEm}</em>
    </h1>
  </div>

  {routes.map((route, i) => (
    <RouteCard
      slug={route.slug}
      title={route.titleEn}
      description={route.descriptionEn}
      price={route.price}
      discount={route.discount}
      discountedPrice={route.discountedPrice}
      discountText={route.discountText}
      discountTextEn={route.discountTextEn}
      distance={route.distance}
      duration={route.durationEn}
      difficulty={route.difficulty}
      difficultyLabel={t.route.difficulty[route.difficulty]}
      mapThumbnail={route.mapThumbnail}
      dates={route.dates}
      index={i}
      lang={lang}
      readMore={t.route.readMore}
    />
  ))}

</BaseLayout>
