---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';

const lang = 'sv';
const t = useTranslations(lang);
---

<BaseLayout title={t.contact.thankYouTitle} lang={lang}>
  <div class="min-h-[calc(100vh-65px)] flex flex-col items-center justify-center px-6 md:px-20 text-center">
    <div class="w-12 h-px bg-brand-gold mb-8"></div>
    <h1 class="font-display text-[2.5rem] font-bold mb-6">{t.contact.thankYouTitle}</h1>
    <p class="text-[0.95rem] text-white/50 leading-relaxed max-w-md mb-12">{t.contact.thankYouBody}</p>
    <a href="/routes" class="text-[0.7rem] font-semibold tracking-[0.2em] uppercase text-brand-gold hover:text-white transition-colors">
      {t.contact.thankYouBack}
    </a>
  </div>
</BaseLayout>
