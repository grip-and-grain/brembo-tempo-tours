---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import TourDateCard from '../../components/TourDateCard.astro';
import { fetchRoutes } from '../../lib/sheets';
import { useTranslations } from '../../i18n';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=7200');

const { slug } = Astro.params;
const routes = await fetchRoutes();
const route = routes.find(r => r.slug === slug);
if (!route) return Astro.redirect('/routes');

const lang = 'sv';
const t = useTranslations(lang);
const bodyParagraphs = route.description.split('||').map(p => p.trim()).filter(Boolean);

const diffClass = {
  lätt: 'bg-green-500/10 text-green-400 border border-green-500/25',
  medel: 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/25',
  krävande: 'bg-red-500/10 text-red-400 border border-red-500/25',
}[route.difficulty];
---

<BaseLayout title={route.title} lang={lang} activeNav="routes">

  <!-- Hero -->
  <section class="relative bg-brand-dark flex flex-col justify-end px-6 md:px-20 pb-10 md:pb-14 pt-28 md:pt-32">
    <a href="/routes" class="text-[0.65rem] tracking-[0.2em] uppercase text-white/35 hover:text-brand-gold transition-colors mb-6 w-fit">{t.route.backToRoutes}</a>
    <span class={`inline-flex text-[0.6rem] font-bold tracking-[0.18em] uppercase px-3 py-1 mb-4 w-fit ${diffClass}`}>
      {t.route.difficulty[route.difficulty]} · {route.duration}
    </span>
    <h1 class="font-display font-black leading-[0.95] tracking-tight text-white mb-6" style="font-size: clamp(2rem, 8vw, 5.5rem)">
      {route.title}
    </h1>
    <div class="flex flex-wrap gap-3 md:gap-6 text-white/40 text-[0.85rem]">
      <span>{route.distance} km</span>
      <span>·</span>
      <span>{route.duration}</span>
      <span>·</span>
      <span>{route.region}</span>
    </div>
  </section>

  <!-- Stats strip -->
  <div class="bg-brand-gold grid grid-cols-2 md:grid-cols-5">
    {[
      [route.distance + ' km', t.route.distanceLabel],
      [route.duration, t.route.durationLabel],
      [t.route.difficulty[route.difficulty], t.route.difficultyLabel],
      [route.region, t.route.regionLabel],
    ].map(([val, label], i) => (
      <div class:list={['py-5 px-6 md:py-7 md:px-10', 'md:border-r border-black/[0.12]']}>
        <div class="text-[0.6rem] font-bold tracking-[0.2em] uppercase text-black/45 mb-1">{label}</div>
        <div class="font-display text-[1.2rem] md:text-[1.6rem] font-bold text-black leading-none">{val}</div>
      </div>
    ))}
    <div class="py-5 px-6 md:py-7 md:px-10">
      <div class="text-[0.6rem] font-bold tracking-[0.2em] uppercase text-black/45 mb-1">{t.route.priceLabel}</div>
      {route.discount > 0 ? (
        <div class="flex items-baseline gap-2">
          <span class="font-display text-[0.95rem] font-bold text-black/30 line-through leading-none">{route.price} kr</span>
          <span class="font-display text-[1.2rem] md:text-[1.6rem] font-bold text-black leading-none">{route.discountedPrice} kr</span>
          <span class="text-[0.55rem] font-bold tracking-wide uppercase bg-green-700/20 text-green-900 px-1.5 py-0.5 rounded">-{route.discount}%</span>
        </div>
      ) : (
        <div class="font-display text-[1.2rem] md:text-[1.6rem] font-bold text-black leading-none">{route.price > 0 ? route.price + ' kr' : '—'}</div>
      )}
      {route.discountText && <div class="text-[0.55rem] font-semibold text-green-900/70 mt-0.5">{route.discountText}</div>}

      <div class="text-[0.55rem] text-red-800/70 mt-1">{t.route.priceNote}</div>
    </div>
  </div>

  <!-- Main content + sidebar -->
  <div class="grid grid-cols-1 md:grid-cols-[1fr_360px] border-t border-white/[0.06]">

    <div class="px-6 md:px-20 py-12 md:py-16 md:border-r border-white/[0.06]">

      <div class="prose-custom mb-14">
        {bodyParagraphs.map(p => <p>{p}</p>)}
      </div>

      <div class="mb-14">
        <div class="flex items-center gap-3 text-[0.6rem] font-bold tracking-[0.25em] uppercase text-brand-gold mb-5">
          <div class="w-6 h-px bg-brand-gold"></div>{t.route.highlights}
        </div>
        <div class="flex flex-wrap gap-2">
          {route.highlights.map(h => (
            <span class="text-[0.7rem] border border-white/12 px-3 py-1.5 text-white/50">{h}</span>
          ))}
        </div>
      </div>

      <div class="mb-14">
        <div class="flex items-center gap-3 text-[0.6rem] font-bold tracking-[0.25em] uppercase text-brand-gold mb-5">
          <div class="w-6 h-px bg-brand-gold"></div>{t.route.map}
        </div>
        <div class="w-full md:w-1/2">
          <img src={route.mapThumbnail} alt={`Karta: ${route.title}`} class="w-full h-auto rounded border border-white/10" />
        </div>
      </div>

    </div>

    <!-- Sidebar -->
    <div class="p-6 md:p-10 bg-brand-surface md:sticky md:top-0 md:self-start">
      <h2 class="font-display text-[1.2rem] font-bold mb-6">{t.route.upcomingDates}</h2>
      <div class="space-y-3">
        {route.dates.map(d => (
          <TourDateCard
            date={d.date}
            spots={d.spots}
            spotsLeft={d.spotsLeft}
            routeSlug={route.slug}
            routeTitle={route.title}
            lang={lang}
            signupLabel={t.route.signup}
            spotsOfLabel={t.route.spotsOf}
            spotsLeftLabel={t.route.spotsLeft}
          />
        ))}
      </div>
      <p class="text-[0.72rem] text-white/25 leading-relaxed mt-5">{t.route.sidebarNote}</p>
    </div>

  </div>

</BaseLayout>

<style>
  .prose-custom :global(p) {
    font-size: 0.95rem;
    line-height: 1.9;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1.25rem;
  }
  .prose-custom :global(p:first-child) {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
  }
</style>
